{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/src/app.ts" },
    { "source": "/(.*)", "destination": "/web/$1" }
  ],
  "builds": [
    {
      "src": "api/src/app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/src/app.ts"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
